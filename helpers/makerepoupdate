# used on fedora 43 ws

mkdir -p /srv/work/repo/cache
dnf5 install --disable-repo=\* --enable-repo=fedora,updates,fedora-cisco-openh264 --downloadonly --refresh --setopt=install_weak_deps=True --installroot=/srv/work/repo/cache --use-host-config @workstation-product-environment @core kernel authselect dosfstools nvme-cli btrfs-progs ntfsprogs cryptsetup grub2-efi-x64 shim-x64 efibootmgr grub2-tools grub2-tools-extra grubby chrony langpacks-en

mkdir -p /srv/work/repo/f43/f43ws/packages
find /srv/work/repo/cache -type f -name \*.rpm -exec cp {} /srv/work/repo/f43/f43ws/packages \;

find /srv/work/repo/cache/var/cache/libdnf5/updates-* -iname \*comps\*.xml.zst -exec cp {} /srv/work/repo/f43 \; 
zstd -d /srv/work/repo/f43/*.zst
rm /srv/work/repo/f43/*.zst
mv /srv/work/repo/f43/*.xml /srv/work/repo/f43/comps.xml

createrepo_c -g /srv/work/repo/f43/comps.xml /srv/work/repo/f43/f43ws

cd /srv/work/repo 

tar -cpzf /srv/work/repo/f43.tgz -C f43 /srv/work/repo 

