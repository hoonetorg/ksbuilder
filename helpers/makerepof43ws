# script ran on fedora 43 ws laptop

rm -Rf /srv/work/repo/cache
mkdir -p /srv/work/repo/cache
dnf5 install --disable-repo=\* --enable-repo=fedora,updates,fedora-cisco-openh264 --downloadonly --refresh --setopt=install_weak_deps=True --installroot=/srv/work/repo/cache --use-host-config @workstation-product-environment @core kernel authselect dosfstools nvme-cli btrfs-progs ntfsprogs cryptsetup grub2-efi-x64 shim-x64 efibootmgr grub2-tools grub2-tools-extra grubby chrony langpacks-en

mkdir -p /srv/work/repo/desktop/f43ws/packages
find /srv/work/repo/cache -type f -name \*.rpm -exec cp {} /srv/work/repo/desktop/f43ws/packages \;

find /srv/work/repo/cache/var/cache/libdnf5/updates-* -iname \*comps\*.xml.zst -exec cp {} /srv/work/repo/desktop \; 
zstd -d /srv/work/repo/desktop/*.zst
rm /srv/work/repo/desktop/*.zst
mv /srv/work/repo/desktop/*.xml /srv/work/repo/desktop/comps.xml

createrepo_c -g /srv/work/repo/desktop/comps.xml /srv/work/repo/desktop/f43ws

rm /srv/work/repo/desktop/comps.xml
rm -Rf /srv/work/repo/cache

cd /srv/work/repo 

tar -cpzf /srv/work/repo/f43ws.tgz -C /srv/work/repo/desktop f43ws
